PORT=5000
NODE_ENV=development
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/aidconnect?retryWrites=true&w=majority
JWT_SECRET=aidconnect_jwt_super_secret_key_2026
JWT_REFRESH_SECRET=aidconnect_refresh_jwt_secret_2026
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d
CLIENT_URL=http://localhost:8080
FAST2SMS_API_KEY=your_fast2sms_api_key
FAST2SMS_SENDER_ID=AIDCON
SMS_DLT_TEMPLATE_ID=your_dlt_template_id
FIREBASE_SERVER_KEY=your_firebase_server_key
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_secret
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
ADMIN_EMAIL=admin@aidconnect.org
